───────────────────────────────────────────
#  Discord Music Bot — Environment Configuration
# ─────────────────────────────────────────────────

# ── Discord ──────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# ── Spotify (optional — enables Spotify links) ───
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── YouTube Cookies (optional — bypasses age gate)
# Export cookies from your browser after signing in
# Format: Netscape HTTP Cookie File (cookies.txt)
YOUTUBE_COOKIE=

# ── Bot Settings ─────────────────────────────────
# Default volume (0–100)
DEFAULT_VOLUME=50

# Max songs per queue (0 = unlimited)
MAX_QUEUE_SIZE=100

# Auto-leave channel after N ms of inactivity (0 = never)
AUTO_LEAVE_TIMEOUT=300000

# ── Sharding ─────────────────────────────────────
# Set to "auto" for automatic shard count
SHARD_COUNT=auto
SHARD_SPAWN_TIMEOUT=30000

# ── Database ─────────────────────────────────────
DB_PATH=./database/data

# ── Debug ────────────────────────────────────────
# Set to "true" for verbose DisTube logs
DEBUG=false
